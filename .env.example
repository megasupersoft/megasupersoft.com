# --- Dashboard Auth ---
# Run `npm run setup` to create these automatically.
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
NUXT_SESSION_PASSWORD=

# --- GitHub ---
# Create a personal access token (classic) at https://github.com/settings/tokens
# with admin:org scope for the target organization.
GITHUB_TOKEN=
GITHUB_ORG=megasupersoft

# --- X / Twitter ---
# Create an app at https://developer.twitter.com with read+write permissions.
# Generate OAuth 1.0a consumer keys and access tokens.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Bluesky ---
# Create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=megasupersoft.bsky.social
BLUESKY_APP_PASSWORD=

# --- YouTube ---
# 1. Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
#    (Desktop app type, enable YouTube Data API v3)
# 2. Set client ID and secret below, then run:
#    node scripts/update-socials.mjs --youtube-auth
# 3. Paste the refresh token below.
# 4. Find your channel ID in YouTube Studio > Settings > Channel > Advanced settings
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
